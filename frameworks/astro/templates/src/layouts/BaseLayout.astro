---
interface Props {
  title: string;
}

const { title } = Astro.props;

const session = await Astro.locals.auth?.();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="AI-powered starter kit with Astro" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-gray-50 dark:bg-gray-900">
    <nav class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="text-xl font-bold text-gray-900 dark:text-white">
            Agentic App
          </a>
          <div class="flex items-center gap-4">
            <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">
              Home
            </a>
            {session ? (
              <>
                <a href="/dashboard" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">
                  Dashboard
                </a>
                <a href="/chat" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">
                  Chat
                </a>
                <span class="text-gray-600 dark:text-gray-400">
                  {session.user?.name || session.user?.email}
                </span>
              </>
            ) : (
              <a
                href="/sign-in"
                class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
              >
                Sign In
              </a>
            )}
          </div>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 mt-auto">
      <div class="container mx-auto px-4 py-6">
        <p class="text-center text-gray-600 dark:text-gray-400">
          Built with Astro and Better Auth
        </p>
      </div>
    </footer>
  </body>
</html>
---
import BaseLayout from '../layouts/BaseLayout.astro';
import { auth } from '../lib/auth';

const session = await auth.api.getSession({
  headers: Astro.request.headers,
});

if (!session) {
  return Astro.redirect('/sign-in');
}
---

<BaseLayout title="Dashboard - Agentic App">
  <div class="container mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-8">Dashboard</h1>
    
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
      <div class="flex items-center gap-4 mb-6">
        <div class="w-16 h-16 bg-gray-200 dark:bg-gray-700 rounded-full flex items-center justify-center">
          <span class="text-2xl font-semibold text-gray-600 dark:text-gray-300">
            {session.user.name?.charAt(0) || session.user.email?.charAt(0) || '?'}
          </span>
        </div>
        <div>
          <h2 class="text-xl font-semibold">{session.user.name || 'User'}</h2>
          <p class="text-gray-600 dark:text-gray-400">{session.user.email}</p>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-4 mt-8">
        <a href="/chat" class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/40 transition-colors">
          <h3 class="font-semibold text-blue-700 dark:text-blue-300">AI Chat</h3>
          <p class="text-sm text-blue-600 dark:text-blue-400">Start a conversation</p>
        </a>
        <a href="/profile" class="p-4 bg-purple-50 dark:bg-purple-900/20 rounded-lg hover:bg-purple-100 dark:hover:bg-purple-900/40 transition-colors">
          <h3 class="font-semibold text-purple-700 dark:text-purple-300">Profile</h3>
          <p class="text-sm text-purple-600 dark:text-purple-400">Manage your account</p>
        </a>
        <a href="/api/auth/sign-out" class="p-4 bg-red-50 dark:bg-red-900/20 rounded-lg hover:bg-red-100 dark:hover:bg-red-900/40 transition-colors">
          <h3 class="font-semibold text-red-700 dark:text-red-300">Sign Out</h3>
          <p class="text-sm text-red-600 dark:text-red-400">Sign out of your account</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>